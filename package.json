{
  "name": "mejoraws",
  "version": "0.1.0",
  "description": "CRM WhatsApp Autónomo con IA — Anti-ban · $0 · 100% local",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "reset:warmup": "rm -f data/warmup.json && echo 'Warm-up reseteado'",
    "reset:session": "rm -rf data/session && echo 'Sesión WhatsApp eliminada'",
    "reset:db": "rm -f data/mejoraws.db && echo 'Base de datos eliminada'"
  },
  "keywords": [
    "whatsapp",
    "crm",
    "ai",
    "bot",
    "marketing",
    "anti-ban",
    "groq",
    "ollama"
  ],
  "author": "pabloeckert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pabloeckert/MejoraWS.git"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
