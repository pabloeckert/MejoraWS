# ============================================
# MejoraWS — Variables de Entorno
# ============================================
# Copiar a .env y configurar:
#   cp .env.example .env
# ============================================

# --- Server ---
NODE_ENV=production
PORT=3000

# --- LLM: Groq API (primario, gratis) ---
# Obtener key en: https://console.groq.com
GROQ_API_KEY=tu-groq-api-key-aqui

# --- LLM: Ollama (backup local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Database ---
DB_PATH=./data/mejoraws.db

# --- WhatsApp Session ---
SESSION_PATH=./data/session

# --- JWT Auth ---
# Generar un secret aleatorio: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# --- Encryption (at-rest) ---
# Generar un secret aleatorio: openssl rand -hex 32
# Cifra la sesión WhatsApp y datos sensibles en disco
ENCRYPTION_SECRET=change-me-to-a-random-encryption-secret

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3001

# --- Logging ---
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- Anti-ban ---
# Modes: conservador, moderado, agresivo
ANTIBAN_MODE=conservador

# --- Schedule ---
SCHEDULE_START_HOUR=8
SCHEDULE_END_HOUR=20
SCHEDULE_TIMEZONE=America/Buenos_Aires
