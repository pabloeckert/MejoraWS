# ============================================
# MejoraWS — Variables de Entorno
# ============================================
# Copiar a .env y configurar:
#   cp .env.example .env
#   nano .env

# === REQUERIDAS ===

# Groq API Key (gratis en https://console.groq.com)
GROQ_API_KEY=gsk_tu_key_aqui

# JWT Secret (generar con: openssl rand -hex 32)
JWT_SECRET=tu_jwt_secret_aqui_min_32_chars

# === OPCIONALES ===

# Entorno (development | production)
NODE_ENV=development

# Puerto del servidor API
PORT=3000

# URL de Ollama (LLM backup local, sin internet)
OLLAMA_URL=http://localhost:11434

# Ruta de la base de datos SQLite
DB_PATH=./data/mejoraws.db

# Ruta de sesión WhatsApp
SESSION_PATH=./data/session

# Nivel de logging (debug | info | warn | error)
LOG_LEVEL=info

# Key para cifrado AES-256-GCM de sesión WhatsApp
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS origin (producción: https://tu-dominio.com)
CORS_ORIGIN=*

# Dashboard URL (para CORS del frontend)
NEXT_PUBLIC_API_URL=http://localhost:3000
